    "lint": "node -e \"const fs=require('fs');const path=require('path');function check(dir){fs.readdirSync(dir).forEach(f=>{const p=path.join(dir,f);const s=fs.statSync(p);if(s.isDirectory()&&f!=='node_modules')check(p);else if(f.endsWith('.js')){try{new Function(fs.readFileSync(p,'utf8'));console.log('OK:',p)}catch(e){console.log('ERROR:',p,e.message);process.exitCode=1}}})}check('.')\""
